  booktitle={2018 IEEE 15th International Symposium on Biomedical Imaging (ISBI 2018)}, 
  title={Dense and structured representations of U-shape fiber connectivity in the central sulcus}, 
  year={2018},
  volume={},
  number={},
  pages={700-703},
  abstract={U-shape fibers are superficial white matter fibers connecting adjacent gyri. In this paper, we present a method to characterize the connectivity of U-shape fibers coursing around the central sulcus. Pre- and post-central gyral crests are semi-automatically drawn and used to build a connectivity space that is identical between subjects. This group space provides a dense representation of the short-range connectivity between the two gyri, as well as a structured representation after clustering.},
