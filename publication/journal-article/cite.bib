AUTHOR={Brun, Lucile and Pron, Alexandre and Sein, Julien and Deruelle, Christine and Coulon, Olivier},   
	 
TITLE={Diffusion MRI: Assessment of the Impact of Acquisition and Preprocessing Methods Using the BrainVISA-Diffuse Toolbox},      
	
JOURNAL={Frontiers in Neuroscience},      
	
VOLUME={13},      

PAGES={536},     
	
YEAR={2019},      
	  
